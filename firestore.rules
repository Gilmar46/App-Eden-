rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'gilmarcoutobrito@gmail.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Validations ---
    function isValidMember(data) {
      return data.name is string && data.name.size() > 0 &&
             data.role is string &&
             data.ministry is string;
    }

    function isValidAnnouncement(data) {
      return data.title is string && data.title.size() > 0;
    }

    function isValidPrayer(data) {
      return data.content is string && data.content.size() > 0 &&
             data.authorId == request.auth.uid;
    }

    function isValidDevotional(data) {
      return data.title is string && data.authorId == request.auth.uid;
    }

    function isValidTransaction(data) {
      return data.amount is number && data.amount > 0 &&
             data.userId == request.auth.uid;
    }

    // --- Public access ---
    match /announcements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /agenda/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /missions/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Authenticated access ---
    match /members/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || isOwner(id));
      allow delete: if isAdmin();
    }

    match /scales/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    match /prayers/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidPrayer(request.resource.data);
      allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['prayerCount']));
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /devotionals/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidDevotional(request.resource.data);
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /chatRooms/{id} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;

      match /messages/{mId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(id)).data.participants;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(id)).data.participants;
      }
    }

    match /financial/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidTransaction(request.resource.data);
    }

    match /admins/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /userProfiles/{id} {
      allow read: if isSignedIn();
      allow write: if isOwner(id);
    }

    match /enrollments/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /bulletins/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
